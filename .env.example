# MongoDB Configuration
# Get your MongoDB connection string from: https://cloud.mongodb.com/
# Format: mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/paithani_ecom?retryWrites=true&w=majority

# JWT Secret
# Generate a secure random string (at least 32 characters)
# Example: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-here-min-32-chars

# Next.js Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000
